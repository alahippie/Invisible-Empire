name: Build and Deploy

on:
  push:
    branches:
      - main

  pull_request:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies (clean + non-interactive)
        run: npm ci
        env:
          CI: true

      - name: Ensure webpack CLI is installed
        run: npm install -D webpack webpack-cli

      - name: Build project (non-interactive webpack)
        run: npx webpack --mode production --no-progress --color
        env:
          CI: true

      - name: Run audit (non-blocking)
        run: npm audit --audit-level=high || true

  deploy:
    needs: build
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main'

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies (production only)
        run: npm ci --omit=dev
        env:
          CI: true

      - name: Build project
        run: npx webpack --mode production --no-progress --color

